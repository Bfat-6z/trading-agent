# ============================================================
# TradingAgents Crypto — Environment Variables
# Copy to .env and fill in real keys. NEVER commit .env to git.
# ============================================================

# ----- LLM (REQUIRED) -----
OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
TRADINGAGENTS_LLM_PROVIDER=9router
LLM_PROVIDER=9router
NINEROUTER_BASE_URL=http://localhost:20128/v1
NINEROUTER_API_KEY=replace_me_or_local_proxy
TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.5
TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.5
TRADINGAGENTS_JUDGE_LLM=gpt-5.5

# ----- Crypto Data APIs -----
# Required (free tiers, sign up at links)
BASESCAN_API_KEY=                  # https://basescan.org/myapikey
MORALIS_API_KEY=                   # https://admin.moralis.com

# Optional
CRYPTOPANIC_API_KEY=               # https://cryptopanic.com/developers/api
LUNARCRUSH_API_KEY=                # https://lunarcrush.com/developers/api
GOPLUS_API_KEY=                    # Free unlimited even without key

# ----- Execution Layer (Phase 00: paper-only) -----
TRADING_AGENT_MODE=paper_learning
TRADING_AGENT_LIVE_ORDERS=false
LIVE_EXECUTION_ENABLED=false
BASE_RPC_URL=https://mainnet.base.org
# Optional read-only data RPC only:
# ALCHEMY_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ----- Bot Wallet -----
# Keep empty during paper/shadow learning. Never put private keys in env.
BOT_WALLET_PATH=

# ----- Safety / Behavior -----
DRY_RUN=true                       # true = print decisions, no on-chain tx
MAX_POSITION_USD=0.0               # live/on-chain max disabled in paper-only mode
DAILY_LOSS_LIMIT_USD=3.0           # circuit breaker — halt for 24h if hit
SLIPPAGE_BPS=300                   # 3% slippage tolerance
MAX_CONCURRENT_POSITIONS=3         # max open positions at once

# ----- Logging -----
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
STATE_DIR=state                    # relative path for runtime state
